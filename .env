# // ---  CREDENTIALS --- //
TELEGRAM_TOKEN=your_bot_token_from_botfather
GROQ_API_KEY=your_groq_api_key
BRAVE_API_KEY=your_brave_api_key
GEMINI_API_KEY=your_gemini_api_key
WEATHER_API_KEY=your_weather_api_key

# // --- OWNER & SYSTEM --- //
# Note: Get your ID by messaging @userinfobot on Telegram
OWNER_ID=your_numerical_telegram_id 
PREFIX=.

# // --- TELEGRAM SPECIFIC --- //
# The ID of the group where the bot should send welcome messages
# (Groups usually start with a minus, e.g., -100123456789)
WELCOME_GROUP_ID=your_group_chat_id
LOG_GROUP_ID=your_log_group_id

# --- Support Link ---
SUPPORT_LINK=https://t.me/your_telegram_group_link
