# // ---  CREDENTIALS --- //
TELEGRAM_TOKEN=your_bot_token_from_botfather
GROQ_API_KEY=your_groq_api_key
BRAVE_API_KEY=your_brave_api_key
GEMINI_API_KEY=your_gemini_api_key
WEATHER_API_KEY=your_weather_api_key

# // --- OWNER & SYSTEM --- //
OWNER_ID=123456789  # Your numerical ID from @userinfobot
PREFIX=.

# // --- TELEGRAM SPECIFIC --- //
WELCOME_GROUP_ID=-100123456789  # Your group ID (with minus sign)
WELCOME_TOPIC_ID=59  # If using topics, otherwise leave empty
LOG_GROUP_ID=-100987654321  # Separate group for logs

# // --- WELCOME SYSTEM ENHANCEMENTS --- #
WELCOME_DM=true  # Send private welcome message
AI_WELCOMES=true  # Use AI for dynamic welcomes

# // --- WELCOME IMAGE (Optional) --- #
# Upload an image to a free image host like imgbb.com or postimages.org
WELCOME_IMAGE_URL=https://i.ibb.co/your-image/welcome.jpg

# // --- LINKS (Without @ symbol) --- #
RULES_LINK=your_rules_channel_username  # e.g., eagle_rules
CHANNEL_LINK=your_announcement_channel  # e.g., eagle_announcements
SUPPORT_LINK=https://t.me/your_group_link  # Your public group invite link
ANNOUNCE_CHANNEL_ID=-100555555555  # Channel ID for announcements

# // --- MESSAGE STYLES --- #
WELCOME_STYLE=military  # Options: military, futuristic, friendly, ai